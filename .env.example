# ─────────────────────────────────────────────────────────────────
#  VUU Writing Center — Environment Variables
#  1. Copy this file: cp .env.example .env
#  2. Fill in every value marked REQUIRED
#  3. NEVER commit .env to Git (it's in .gitignore)
# ─────────────────────────────────────────────────────────────────

# Server
PORT=3001
NODE_ENV=production

# ── CORS ─────────────────────────────────────────────────────────
# Your Vercel frontend URL — set this after deploying to Vercel.
# Example: https://vuu-writing-center.vercel.app
# The backend also accepts any *.vercel.app URL automatically (for preview deploys).
FRONTEND_ORIGIN=https://your-project.vercel.app   # REQUIRED

# ── Admin dashboard ───────────────────────────────────────────────
# Password to log into /admin — make it strong!
ADMIN_PASSWORD=change_this_to_a_strong_password   # REQUIRED

# ── Email (Gmail SMTP) ────────────────────────────────────────────
# Use a Gmail account with an App Password.
# Setup: Google Account → Security → 2-Step Verification → App Passwords
# Generate a password for "Mail" and paste it below.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=writingcenter@vuu.edu                  # REQUIRED
EMAIL_PASS=your_16_char_gmail_app_password        # REQUIRED

# Where staff notification emails are sent
STAFF_EMAIL=writingcenter@vuu.edu                 # REQUIRED

# Outbound email display name and address
FROM_NAME=VUU Writing Center
FROM_EMAIL=writingcenter@vuu.edu

# ── File uploads ──────────────────────────────────────────────────
# On Render free tier, use /tmp (ephemeral but works for email attachments).
# For persistent storage, use a mounted disk (Render paid) or point to S3.
UPLOAD_DIR=/tmp/vuu-uploads
MAX_FILE_SIZE_MB=10

# ── Database ──────────────────────────────────────────────────────
# SQLite file path.
# On Render free tier: store in /tmp (resets on restart).
# For persistence: use Render's "Disk" add-on and set a path under /var/data,
# OR migrate to PostgreSQL (see README).
DB_PATH=/tmp/vuu-writing-center.db
