# ─────────────────────────────────────────────────────────────────
#  VUU Writing Center — Backend Environment Variables
#  Copy this file to .env and fill in your real values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# Server
PORT=3001
NODE_ENV=production

# Frontend origin (for CORS — your deployed site URL)
FRONTEND_ORIGIN=https://writingcenter.vuu.edu

# Admin dashboard password (change this!)
ADMIN_PASSWORD=changeme_strong_password_here

# ── Email (Nodemailer via Gmail) ──────────────────────────────────
# Use a Gmail account with an App Password (not your real password).
# Enable 2FA on the account, then generate an App Password at:
# https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=writingcenter@vuu.edu
EMAIL_PASS=your_gmail_app_password_here

# Where staff notification emails go
STAFF_EMAIL=writingcenter@vuu.edu

# Reply-to address shown to students
FROM_NAME=VUU Writing Center
FROM_EMAIL=writingcenter@vuu.edu

# ── File storage ──────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# ── Database ──────────────────────────────────────────────────────
DB_PATH=./data/vuu_writing_center.db
