# ============================================================
# VUU Writing Center — Backend Environment Variables
# Copy this file to .env and fill in your real values
# ============================================================

# Server
PORT=4000

# Admin password (simple — no login system)
ADMIN_PASSWORD=change-me-to-something-secure
# A random string used to sign admin session tokens
ADMIN_SECRET=replace-with-a-long-random-string-32chars

# Frontend origin (your Vercel URL — no trailing slash)
FRONTEND_ORIGIN=https://vuu-writing-center.vercel.app

# Email settings (nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-gmail-app-password
STAFF_EMAIL=writingcenter@vuu.edu

# SQLite file path (relative to backend root)
DB_PATH=./data/writing_center.db

# Uploads folder (relative to backend root)
UPLOADS_PATH=./uploads
